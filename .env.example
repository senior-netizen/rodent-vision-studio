# Core runtime mode
NODE_ENV=development

# Contact API (Resend)
RESEND_API_KEY=
CONTACT_TO_EMAIL=you@rodent.co.zw
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Cloudinary (required in production)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Feature flags (1/0 or true/false)
FEATURE_ANALYTICS=true
FEATURE_CONTACT_FORM=true
FEATURE_AUTOMATION=false
